    {
      "id": 6,
      "slug": "live-chat-module",
      "title": "Live Chat Module",
      "category": "Overlays",
      "subcategory": "Chat",
      "tags": ["css-only", "obs", "animated", "chat", "live"],
      "license": "CC0 1.0",
      "version": "1.0.0",
      "description": "A minimal solid-panel chat overlay with a neon laser sweep animation on the header. Clean typography, no clutter.",
      "usage": "OBS Browser Source — recommended size 380x500px",
      "editorPage": "Overlay6.html",
      "defaults": {
        "containerWidth": 360,
        "containerHeight": 480,
        "bgSolid": "#060608",
        "headerBg": "#0b0b0f",
        "neonColor": "#ffffff",
        "headerLabel": "Live Chat",
        "messages": [
          { "user": "Heaven501", "text": "The multi-layered shadow makes the white laser look incredibly intense now." },
          { "user": "Scorpiour", "text": "Perfect. It completely feels like a real production overlay." }
        ]
