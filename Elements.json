      "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<link href=\"https://fonts.googleapis.com/css2?family=Exo+2:wght@900&display=swap\" rel=\"stylesheet\">\n\t<style>\n\t\t:root { --bg-solid-matte: {{headerBg}}; --chat-body-solid: {{bgSolid}}; --neon-core: {{neonColor}}; --neon-glow: 0 0 4px {{neonColor}}, 0 0 12px rgba(255,255,255,0.8), 0 0 25px rgba(255,255,255,0.4), 0 0 40px rgba(255,255,255,0.2); --container-width: {{containerWidth}}px; --container-height: {{containerHeight}}px; }\n\t\tbody { margin: 0; padding: 0; background: transparent; font-family: 'Exo 2', sans-serif; }\n\t\t.chat-module-container { width: var(--container-width); height: var(--container-height); display: flex; flex-direction: column; background: var(--chat-body-solid); border: 1px solid rgba(255,255,255,0.03); border-radius: 6px; box-shadow: 0 30px 60px rgba(0,0,0,0.8); position: relative; overflow: hidden; }\n\t\t.chat-header { width: 100%; background: var(--bg-solid-matte); padding: 14px 20px; display: flex; align-items: center; gap: 12px; position: relative; z-index: 2; flex-shrink: 0; }\n\t\t.chat-header::before { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: rgba(255,255,255,0.08); }\n\t\t.chat-header::after { content: ''; position: absolute; bottom: -0.5px; left: 0; width: 70px; height: 1px; background: var(--neon-core); box-shadow: var(--neon-glow); z-index: 3; animation: razorSweep 3s infinite alternate cubic-bezier(0.4,0,0.2,1); }\n\t\t.header-icon { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; border-left: 2px solid var(--neon-core); padding-left: 4px; }\n\t\t.header-icon svg { width: 13px; height: 13px; fill: var(--neon-core); }\n\t\t.header-text { color: var(--neon-core); font-size: 13px; font-weight: 900; text-transform: uppercase; letter-spacing: 2.5px; }\n\t\t.chat-body-view { flex: 1; width: 100%; padding: 20px; display: flex; flex-direction: column; gap: 14px; overflow: hidden; }\n\t\t.msg-row { font-size: 13px; line-height: 1.4; animation: textReveal 0.3s ease-out both; }\n\t\t.msg-user { font-weight: 900; color: #ffffff; opacity: 0.9; margin-right: 6px; }\n\t\t.msg-text { font-weight: 400; color: #7e7e8a; }\n\t\t@keyframes razorSweep { 0% { left: 0%; transform: translateX(0%); } 100% { left: 100%; transform: translateX(-100%); } }\n\t\t@keyframes textReveal { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }\n\t</style>\n</head>\n<body>\n\t<div class=\"chat-module-container\">\n\t\t<div class=\"chat-header\">\n\t\t\t<div class=\"header-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z\"/></svg></div>\n\t\t\t<span class=\"header-text\">{{headerLabel}}</span>\n\t\t</div>\n\t\t<div class=\"chat-body-view\" id=\"chat-body\"></div>\n\t</div>\n\t<script>\n\t\tconst messages = {{messagesJSON}};\n\t\tconst body = document.getElementById('chat-body');\n\t\tmessages.forEach((m,i) => { const row = document.createElement('div'); row.className='msg-row'; row.style.animationDelay=(i*0.1)+'s'; row.innerHTML=`<span class=\"msg-user\">${m.user}</span><span class=\"msg-text\">${m.text}</span>`; body.appendChild(row); });\n\t<\/script>\n</body>\n</html>"
