      "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<link href=\"https://fonts.googleapis.com/css2?family=Exo+2:wght@700;900&display=swap\" rel=\"stylesheet\">\n\t<style>\n\t\t:root { --color-twitter: {{twitterColor}}; --color-twitch: {{twitchColor}}; --color-youtube: {{youtubeColor}}; }\n\t\tbody { margin: 0; padding: 0; background: transparent; font-family: 'Exo 2', sans-serif; }\n\t\t.breadcrumb-anchor { position: fixed; top: {{positionTop}}; left: {{positionLeft}}; height: 44px; display: inline-flex; align-items: center; }\n\t\t.bc-pill { position: absolute; left: 0; top: 0; height: 100%; background: #0a0a0c; border-radius: 22px; border: 2px solid rgba(255,255,255,0.06); display: flex; align-items: center; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.5); animation: cycleSequence 15s infinite ease-in-out; opacity: 0; width: 0; }\n\t\t.bc-pill.twitter { animation-delay: 0s; --platform-color: var(--color-twitter); }\n\t\t.bc-pill.twitch  { animation-delay: 5s;  --platform-color: var(--color-twitch); }\n\t\t.bc-pill.youtube { animation-delay: 10s; --platform-color: var(--color-youtube); }\n\t\t.bc-content { display: flex; align-items: center; width: 240px; height: 100%; padding-left: 6px; }\n\t\t.bc-icon-box { width: 32px; height: 32px; border-radius: 50%; background: var(--platform-color); display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 0 10px var(--platform-color); }\n\t\t.bc-icon-box svg { width: 16px; height: 16px; fill: #fff; }\n\t\t.bc-text-container { display: flex; flex-direction: column; padding-left: 12px; }\n\t\t.bc-platform-label { font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; color: var(--platform-color); line-height: 1; }\n\t\t.bc-handle { font-size: 14px; font-weight: 700; color: #ffffff; line-height: 1.3; }\n\t\t@keyframes cycleSequence { 0% { width: 44px; opacity: 0; transform: scale(0.9) translateX(-10px); } 3.33% { opacity: 1; transform: scale(1) translateX(0); } 6.66%, 26.66% { width: 220px; opacity: 1; } 30% { width: 44px; opacity: 1; } 33.33%, 100% { width: 44px; opacity: 0; transform: scale(0.9) translateX(10px); } }\n\t</style>\n</head>\n<body>\n\t<div class=\"breadcrumb-anchor\">\n\t\t<div class=\"bc-pill twitter\"><div class=\"bc-content\"><div class=\"bc-icon-box\"><svg viewBox=\"0 0 24 24\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/></svg></div><div class=\"bc-text-container\"><span class=\"bc-platform-label\">Twitter</span><span class=\"bc-handle\">{{twitterHandle}}</span></div></div></div>\n\t\t<div class=\"bc-pill twitch\"><div class=\"bc-content\"><div class=\"bc-icon-box\"><svg viewBox=\"0 0 24 24\"><path d=\"M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z\"/></svg></div><div class=\"bc-text-container\"><span class=\"bc-platform-label\">Twitch</span><span class=\"bc-handle\">{{twitchHandle}}</span></div></div></div>\n\t\t<div class=\"bc-pill youtube\"><div class=\"bc-content\"><div class=\"bc-icon-box\"><svg viewBox=\"0 0 24 24\"><path d=\"M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z\"/></svg></div><div class=\"bc-text-container\"><span class=\"bc-platform-label\">YouTube</span><span class=\"bc-handle\">{{youtubeHandle}}</span></div></div></div>\n\t</div>\n</body>\n</html>"
