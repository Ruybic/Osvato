      "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<link href=\"https://fonts.googleapis.com/css2?family=Exo+2:wght@700;900&display=swap\" rel=\"stylesheet\">\n\t<style>\n\t\t:root { --goal-accent: {{accentColor}}; --track-bg: {{trackBg}}; }\n\t\tbody { margin: 0; padding: 0; background: transparent; font-family: 'Exo 2', sans-serif; }\n\t\t.goal-container { width: 380px; position: fixed; top: {{positionTop}}; left: {{positionLeft}}; display: flex; flex-direction: column; gap: 6px; }\n\t\t.goal-header { display: flex; justify-content: space-between; align-items: flex-end; padding: 0 4px; }\n\t\t.goal-title { font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1.5px; color: #8888a0; }\n\t\t.goal-values { font-size: 13px; font-weight: 900; color: #fff; }\n\t\t.goal-values span { color: var(--goal-accent); }\n\t\t.goal-track { height: 16px; background: var(--track-bg); border-radius: 4px; overflow: hidden; border: 1px solid rgba(255,255,255,0.04); position: relative; transform: skewX(-15deg); }\n\t\t.goal-fill { height: 100%; width: {{fillPercent}}%; background: linear-gradient(90deg, var(--track-bg), var(--goal-accent)); position: relative; border-radius: 2px; box-shadow: 3px 0 12px var(--goal-accent); }\n\t\t.goal-fill::after { content: ''; position: absolute; top: 0; bottom: 0; left: 0; right: 0; background-image: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%); background-size: 40px 100%; background-repeat: no-repeat; animation: warpDrive 1.8s infinite linear; }\n\t\t@keyframes warpDrive { 0% { background-position: -40px 0; } 100% { background-position: calc(100% + 40px) 0; } }\n\t</style>\n</head>\n<body>\n\t<div class=\"goal-container\">\n\t\t<div class=\"goal-header\">\n\t\t\t<span class=\"goal-title\">{{label}}</span>\n\t\t\t<span class=\"goal-values\"><span>{{currentValue}}</span> / {{targetValue}} {{unit}}</span>\n\t\t</div>\n\t\t<div class=\"goal-track\"><div class=\"goal-fill\"></div></div>\n\t</div>\n</body>\n</html>"
