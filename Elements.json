      "license": "CC0 1.0",
      "version": "1.0.0",
      "description": "A sleek animated info plate that cycles through beatmap metadata — title, artist and mapper — with a sliding entrance animation and accent glow.",
      "usage": "OBS Browser Source — recommended size 380x100px",
      "editorPage": "Overlay3.html",
      "defaults": {
        "accentColor": "#ff66aa",
        "imageUrl": "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=150",
        "maps": [
          { "tag": "Now Playing", "title": "IMAGE -MATERIAL-", "artist": "Tatsh", "mapper": "Scorpiour" },
          { "tag": "Now Playing", "title": "Harumachi Clover", "artist": "Swing Holic", "mapper": "Sotarks" },
