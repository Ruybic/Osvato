      "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<link href=\"https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;800;900&display=swap\" rel=\"stylesheet\">\n\t<style>\n\t\t:root { --accent-glow: {{accentColor}}; }\n\t\tbody { margin: 0; padding: 0; background: transparent; font-family: 'Exo 2', sans-serif; color: #fff; }\n\t\t.info-plate { position: relative; width: 340px; background: rgba(10,10,14,0.92); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 16px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); display: flex; gap: 14px; align-items: center; overflow: hidden; }\n\t\t.info-plate::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--accent-glow); }\n\t\t.map-jacket-wrap { width: 64px; height: 64px; flex-shrink: 0; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.15); }\n\t\t.map-jacket { width: 100%; height: 100%; background: url('{{imageUrl}}') center/cover; }\n\t\t.map-meta { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 0; }\n\t\t.meta-tag { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: var(--accent-glow); margin-bottom: 2px; }\n\t\t.map-title { font-size: 15px; font-weight: 900; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #fff; }\n\t\t.map-artist { font-size: 12px; font-weight: 600; color: #a0a0c0; }\n\t\t.map-mapper { font-size: 11px; font-weight: 400; color: #666680; margin-top: 2px; }\n\t\t.map-mapper span { color: #8888a8; font-weight: 600; }\n\t\t@keyframes slideIn { from { transform: translateX(-30px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }\n\t\t.info-plate.animating { animation: slideIn 0.6s cubic-bezier(0.16,1,0.3,1) both; }\n\t</style>\n</head>\n<body>\n\t<div class=\"info-plate\" id=\"plate\">\n\t\t<div class=\"map-jacket-wrap\"><div class=\"map-jacket\"></div></div>\n\t\t<div class=\"map-meta\"><div class=\"meta-tag\" id=\"p-tag\"></div><div class=\"map-title\" id=\"p-title\"></div><div class=\"map-artist\" id=\"p-artist\"></div><div class=\"map-mapper\">Mapped by <span id=\"p-mapper\"></span></div></div>\n\t</div>\n\t<script>\n\t\tconst maps = {{mapsJSON}};\n\t\tlet i = 0;\n\t\tfunction show(idx) { const m=maps[idx]; const p=document.getElementById('plate'); p.classList.remove('animating'); void p.offsetWidth; p.classList.add('animating'); document.getElementById('p-tag').textContent=m.tag; document.getElementById('p-title').textContent=m.title; document.getElementById('p-artist').textContent=m.artist; document.getElementById('p-mapper').textContent=m.mapper; }\n\t\tshow(0); setInterval(()=>{ i=(i+1)%maps.length; show(i); },5000);\n\t<\/script>\n</body>\n</html>"
