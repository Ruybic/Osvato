      "id": 1,
      "slug": "3d-expanding-watermark",
      "title": "3D Expanding Watermark",
      "category": "Overlays",
      "subcategory": "Watermarks",
      "tags": ["css-only", "obs", "animated", "3d", "watermark"],
      "license": "CC0 1.0",
      "version": "1.0.0",
      "description": "A CSS-animated 3D watermark that expands from a circle into a pill shape, with a floating avatar, username, and particle effects.",
      "usage": "OBS Browser Source — recommended size 400x120px",
      "editorPage": "Overlay1.html",
      "defaults": {
        "color1": "#0391e2",
        "color2": "#52b8ff",
        "text": "Osvato",
        "imageUrl": "https://litter.catbox.moe/jqckapgn7924tm9q.png",
        "positionTop": "30px",
        "positionLeft": "30px",
        "particleShape": "triangle",
        "particleColor": "#ffffff",
        "particleOpacity": 0.25
      },
      "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n\t<link href=\"https://fonts.googleapis.com/css2?family=Exo+2:wght@900&display=swap\" rel=\"stylesheet\">\n\t<style>\n\t\t:root { --brand-blue: {{color1}}; --light-blue: {{color2}}; }\n\t\t.wm-anchor { position: fixed; top: {{positionTop}}; left: {{positionLeft}}; perspective: 1000px; z-index: 9999; font-family: 'Exo 2', sans-serif; }\n\t\t.wm-3d-wrapper { animation: float3D 6s infinite ease-in-out; transform-style: preserve-3d; }\n\t\t.wm-shape { position: relative; height: 64px; border-radius: 32px; border: 4px solid #fff; overflow: hidden; background: linear-gradient(90deg, var(--brand-blue), var(--light-blue), var(--brand-blue)); background-size: 200%; box-shadow: -5px 15px 25px rgba(0,0,0,0.2); animation: expandCollapse 10s infinite cubic-bezier(0.65, 0, 0.15, 1), moveBg 3s linear infinite; }\n\t\t.wm-tri { position: absolute; bottom: -20px; width: 0; height: 0; border-left: 10px solid transparent; border-right: 10px solid transparent; border-bottom: 15px solid {{particleColor}}; animation: miniFloat 3s infinite linear; }\n\t\t.wm-content { display: flex; align-items: center; height: 100%; width: 230px; }\n\t\t.wm-icon { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; padding-left: 4.9px; }\n\t\t/* Replace image URL with your hosted URL or local path: file:///C:/StreamAssets/avatar.png */\n\t\t.wm-pic { width: 44px; height: 44px; border-radius: 50%; background: url('{{imageUrl}}') center/cover; border: 2px solid #fff; }\n\t\t.wm-text { color: white; font-weight: 900; font-size: 18px; padding-left: 12px; white-space: nowrap; }\n\t\t@keyframes float3D { 0%, 100% { transform: rotateY(25deg) rotateX(10deg) translateY(0); } 50% { transform: rotateY(20deg) rotateX(15deg) translateY(-8px); } }\n\t\t@keyframes expandCollapse { 0%, 15% { width: 64px; } 30%, 85% { width: 240px; } 100% { width: 64px; } }\n\t\t@keyframes moveBg { to { background-position: 200% center; } }\n\t\t@keyframes miniFloat { 0% { transform: translateY(0); opacity: 0; } 50% { opacity: 1; } 100% { transform: translateY(-80px) rotate(30deg); opacity: 0; } }\n\t</style>\n</head>\n<body>\n\t<div class=\"wm-anchor\">\n\t\t<div class=\"wm-3d-wrapper\">\n\t\t\t<div class=\"wm-shape\">\n\t\t\t\t<div class=\"wm-tri\" style=\"left: 20%; animation-delay: 0s;\"></div>\n\t\t\t\t<div class=\"wm-tri\" style=\"left: 60%; animation-delay: 1.5s;\"></div>\n\t\t\t\t<div class=\"wm-content\">\n\t\t\t\t\t<div class=\"wm-icon\"><div class=\"wm-pic\"></div></div>\n\t\t\t\t\t<div class=\"wm-text\">{{text}}</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</body>\n</html>"
