{
  "id": "overlay-wm01",
  "slug": "3d-expanding-watermark",
  "title": "3D Expanding Watermark",
  "category": "Overlays",
  "subcategory": "Watermarks",
  "tags": ["css-only", "obs", "browser-source", "animated", "3d", "watermark"],
  "license": "CC0 1.0",
  "version": "1.0.0",
  "author": "Heaven501",
  "description": "A fully CSS-animated 3D watermark that expands from a circle into a pill shape, featuring a floating avatar, username, and subtle particle triangles. Designed for OBS Browser Source.",
  "usage": "OBS Browser Source — recommended size 400x120px",
  "defaults": {
    "color1": "#0391e2",
    "color2": "#52b8ff",
    "text": "@Heaven501",
    "imageUrl": "https://litter.catbox.moe/jqckapgn7924tm9q.png",
    "positionTop": "30px",
    "positionLeft": "30px",
    "particleShape": "triangle",
    "particleColor": "rgba(255,255,255,0.25)"
  },
  "customizableFields": [
    { "key": "color1",        "label": "Main Color",       "type": "color" },
    { "key": "color2",        "label": "Highlight Color",  "type": "color" },
    { "key": "text",          "label": "Username Text",    "type": "text" },
    { "key": "imageUrl",      "label": "Avatar Image URL", "type": "image-url" },
    { "key": "positionTop",   "label": "Position Top",     "type": "text" },
    { "key": "positionLeft",  "label": "Position Left",    "type": "text" },
    { "key": "particleShape", "label": "Particle Shape",   "type": "select", "options": ["triangle", "circle", "diamond"] },
    { "key": "particleColor", "label": "Particle Color",   "type": "color-alpha" }
  ],
  "previewNote": "Avatar image uses a placeholder URL. When exporting for OBS, replace the image URL with an absolute path on your machine (e.g. C:/StreamAssets/avatar.png) or a hosted URL.",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n\t<link href=\"https://fonts.googleapis.com/css2?family=Exo+2:wght@900&display=swap\" rel=\"stylesheet\">\n\t<style>\n\t\t:root { --brand-blue: {{color1}}; --light-blue: {{color2}}; }\n\t\t\n\t\t.wm-anchor { \n\t\t\tposition: fixed; top: {{positionTop}}; left: {{positionLeft}}; perspective: 1000px; z-index: 9999; font-family: 'Exo 2', sans-serif; \n\t\t}\n\t\t.wm-3d-wrapper {\n\t\t\tanimation: float3D 6s infinite ease-in-out;\n\t\t\ttransform-style: preserve-3d;\n\t\t}\n\n\t\t.wm-shape {\n\t\t\tposition: relative; height: 64px; \n\t\t\tborder-radius: 32px; border: 4px solid #fff; overflow: hidden;\n\t\t\tbackground: linear-gradient(90deg, var(--brand-blue), var(--light-blue), var(--brand-blue));\n\t\t\tbackground-size: 200%;\n\t\t\tbox-shadow: -5px 15px 25px rgba(0,0,0,0.2);\n\t\t\tanimation: expandCollapse 10s infinite cubic-bezier(0.65, 0, 0.15, 1), moveBg 3s linear infinite;\n\t\t}\n\n\t\t.wm-tri {\n\t\t\tposition: absolute; bottom: -20px; width: 0; height: 0;\n\t\t\tborder-left: 10px solid transparent; border-right: 10px solid transparent;\n\t\t\tborder-bottom: 15px solid {{particleColor}};\n\t\t\tanimation: miniFloat 3s infinite linear;\n\t\t}\n\n\t\t.wm-content { display: flex; align-items: center; height: 100%; width: 230px; }\n\t\t\n\t\t.wm-icon { \n\t\t\twidth: 56px; height: 56px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; padding-left: 4.9px; }\n\t\t/* \u26a0 IMPORTANT: Replace the image URL below with your local file path or hosted URL */\n\t\t/* Example local path: url('file:///C:/StreamAssets/avatar.png') */\n\t\t.wm-pic { width: 44px; height: 44px; border-radius: 50%; background: url('{{imageUrl}}') center/cover; border: 2px solid #fff; }\n\t\t\n\t\t.wm-text { color: white; font-weight: 900; font-size: 18px; padding-left: 12px; white-space: nowrap; }\n\n\t\t@keyframes float3D { \n\t\t\t0%, 100% { transform: rotateY(25deg) rotateX(10deg) translateY(0); } \n\t\t\t50% { transform: rotateY(20deg) rotateX(15deg) translateY(-8px); } \n\t\t}\n\t\t@keyframes expandCollapse {\n\t\t\t0%, 15% { width: 64px; }\n\t\t\t30%, 85% { width: 240px; }\n\t\t\t100% { width: 64px; }\n\t\t}\n\t\t@keyframes moveBg { to { background-position: 200% center; } }\n\t\t@keyframes miniFloat {\n\t\t\t0% { transform: translateY(0); opacity: 0; }\n\t\t\t50% { opacity: 1; }\n\t\t\t100% { transform: translateY(-80px) rotate(30deg); opacity: 0; }\n\t\t}\n\t</style>\n</head>\n<body>\n\t<div class=\"wm-anchor\">\n\t\t<div class=\"wm-3d-wrapper\">\n\t\t\t<div class=\"wm-shape\">\n\t\t\t\t<div class=\"wm-tri\" style=\"left: 20%; animation-delay: 0s;\"></div>\n\t\t\t\t<div class=\"wm-tri\" style=\"left: 60%; animation-delay: 1.5s;\"></div>\n\t\t\t\t\n\t\t\t\t<div class=\"wm-content\">\n\t\t\t\t\t<div class=\"wm-icon\"><div class=\"wm-pic\"></div></div>\n\t\t\t\t\t<div class=\"wm-text\">{{text}}</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</body>\n</html>"
}
